{
    "name": "diwa",
    "scripts": {
        "dev": "bun run src/db/migrate.ts && bun run --hot src/index.ts",
        "db:migrate": "bun run src/db/migrate.ts",
        "db:fresh": "bun run src/db/fresh.ts && bun run src/db/migrate.ts",
        "db:reset": "rm -rf data && bun run db:migrate"
    },
    "dependencies": {
        "@scalar/hono-api-reference": "^0.11.8",
        "hono": "^4.12.27",
        "hono-rate-limiter": "^0.5.3",
        "puppeteer-core": "^25.3.0"
    },
    "devDependencies": {
        "@types/bun": "latest"
    }
}
